# ===== 必填 =====
# ⚠️ 必须填入有效 Key，否则应用无法正常工作
OPENAI_API_KEY=
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# ===== 模型 =====
OPENAI_MODEL=glm-4-flash

# ===== JWT 安全（务必修改！） =====
# ⚠️ 生产环境务必修改为随机字符串，建议: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-me-to-a-random-string

# ===== CORS =====
# ⚠️ 替换为你的实际域名
APP_CORS_ORIGINS=["http://your-domain.com","https://your-domain.com"]

# ===== 日志 =====
APP_LOG_LEVEL=INFO

# ===== 持久化 =====
PERSISTENCE_BACKEND=sqlite
SQLITE_PATH=/app/data/chat.db

# ===== RAG 知识库 =====
ENABLE_RAG=true
RAG_SOURCE_DIR=/app/knowledge
DOCUMENT_STORE_DIR=/app/data/documents
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
RAG_TOP_K=4
RAG_EMBEDDING_MODEL=embedding-3
RAG_EMBEDDING_DIMENSIONS=128

# ===== 文档上传限制 =====
MAX_UPLOAD_BYTES=20971520                   # 20MB
ALLOWED_DOCUMENT_EXTENSIONS=[".txt",".md",".pdf",".docx"]